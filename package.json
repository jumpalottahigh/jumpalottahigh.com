{
  "name": "jumpalottahigh.com",
  "version": "0.2.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "publish-drafts": "node -e \"const {createClient}=require('next-sanity');require('fs').readFileSync('.env.local','utf8').split('\\n').forEach(l=>{const[k,...v]=l.split('=');if(k&&v.length)process.env[k.trim()]=v.join('=').trim()});const c=createClient({projectId:process.env.NEXT_PUBLIC_SANITY_PROJECT_ID,dataset:'production',apiVersion:'2024-01-01',token:process.env.SANITY_API_TOKEN,useCdn:false});c.fetch('*[_id in path(\\\"drafts.**\\\")]').then(ds=>{if(!ds.length)return console.log('No drafts.');const tx=c.transaction();ds.forEach(d=>{tx.createOrReplace({...d,_id:d._id.replace('drafts.','')});tx.delete(d._id)});return tx.commit()}).then(r=>r&&console.log('Published',r.results.length/2,'document(s)!')).catch(console.error)\""
  },
  "dependencies": {
    "@portabletext/react": "^6.0.3",
    "@sanity/image-url": "^2.1.1",
    "@sanity/vision": "^5.23.0",
    "@vercel/analytics": "^2.0.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.14.0",
    "next": "16.2.4",
    "next-sanity": "^12.4.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "sanity": "^5.23.0",
    "tailwind-merge": "^3.5.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20.19.39",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.4",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
